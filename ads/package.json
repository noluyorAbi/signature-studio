{
  "name": "signature-studio-ads",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion advertisement videos for Signature Studio",
  "scripts": {
    "studio": "remotion studio",
    "render:promo": "remotion render Promo out/signature-studio-promo.mp4 --codec=h264",
    "render:square": "remotion render Square out/signature-studio-square.mp4 --codec=h264",
    "render:gif": "remotion render Square out/signature-studio-ad.gif --codec=gif --every-nth-frame=2"
  },
  "dependencies": {
    "@remotion/cli": "4.0.484",
    "@remotion/google-fonts": "4.0.484",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.484"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "typescript": "5.7.3"
  }
}
